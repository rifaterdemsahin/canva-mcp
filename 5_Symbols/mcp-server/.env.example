# Canva API Credentials
# 1. Go to https://www.canva.com/developers/
# 2. Create or select your app
# 3. Copy the Client ID and Client Secret
#
# Real values live in Azure Key Vault "dp-kv-deliverypilot" (do NOT create a new vault):
#   ../toolbox/secrets.sh get canva-mcp-CANVA-CLIENT-ID
#   ../toolbox/secrets.sh get canva-mcp-CANVA-CLIENT-SECRET

CANVA_CLIENT_ID=your_canva_client_id_here
CANVA_CLIENT_SECRET=your_canva_client_secret_here

# Optional: debug logging
LOG_LEVEL=info
